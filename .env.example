# Environment variables for Shime Events Assistant
# Copy this to .env.local and fill in actual values

# App Configuration
VITE_APP_NAME=Shime Events & Planning
VITE_API_URL=

# Supabase Configuration (required for database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Chapa Payment Gateway (required for payment processing)
VITE_CHAPA_PUBLIC_KEY=CHASECK_TEST_xxxxxxxxxxxxxxxxxxxxx

# Admin Panel Security (required for admin access)
VITE_ADMIN_PASSWORD=YourStrongAdminPasswordHere

# Contact Information (optional)
VITE_WHATSAPP_NUMBER=251912345678
VITE_TELEGRAM_HANDLE=ShimeEvents

# For Vercel Deployment
NODE_ENV=production
